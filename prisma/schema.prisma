// Prisma Schema for MyTraderJournal
// PostgreSQL database schema for trading journal application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MODEL
// ============================================================================
// Core user account information
// Used for authentication and as the root entity for all user data

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  journals     Journal[]

  @@map("users")
  @@index([email])
}

// ============================================================================
// JOURNAL MODEL
// ============================================================================
// Trading journals belong to users
// Each journal tracks a separate trading account or strategy
// Capital is updated after each trade to enable real-time analytics

model Journal {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  name           String
  startingCapital Float    @map("starting_capital") // Initial capital when journal was created
  currentCapital  Float    @map("current_capital")  // Updated after each trade
  tradesCount    Int       @default(0) @map("trades_count") // Number of trades in this journal
  currency       String    @default("USD") // Currency code (USD, EUR, etc.)
  updatedAt      DateTime  @updatedAt @map("updated_at") // Automatically updated on changes
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades         Trade[]
  attributes     JournalAttribute[]

  @@map("journals")
  @@index([userId])
  @@index([userId, createdAt])
}

// ============================================================================
// TRADE MODEL
// ============================================================================
// Individual trades within a journal
// Stores trade inputs, computed metrics, and win/loss status
// Optimized for analytics queries (equity curve, winrate, R/R analysis)

enum TradeOutcome {
  WIN
  LOSS
  BE
}

model Trade {
  id          String        @id @default(uuid())
  journalId   String        @map("journal_id")
  tradeDate   DateTime      @map("trade_date") // Date of the trade (can be historical)
  outcome     TradeOutcome  // WIN, LOSS, or BE
  riskAmount  Float         @map("risk_amount") // Amount risked on this trade
  mainRR      Float?        @map("main_rr") // Main risk-reward ratio (nullable if partials sum to 100%)
  profitLoss  Float         @map("profit_loss") // Computed: profit or loss amount
  rMultiple   Float         @map("r_multiple") // Computed: profitLoss / riskAmount
  isWin       Boolean       @map("is_win") // Computed: derived from profitLoss > 0
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  journal     Journal       @relation(fields: [journalId], references: [id], onDelete: Cascade)
  partials    TradePartial[]
  attributeValues TradeAttributeValue[]

  @@map("trades")
  @@index([journalId])
  @@index([journalId, tradeDate])
  @@index([journalId, outcome])
  @@index([journalId, isWin])
  @@index([journalId, createdAt])
  // Composite index for common analytics queries (equity curve, calendar P&L)
  @@index([journalId, tradeDate, profitLoss])
}

// ============================================================================
// TRADE PARTIAL MODEL
// ============================================================================
// Stores partial exit information for trades
// Each partial represents a percentage of the position closed at a specific RR

model TradePartial {
  id          String    @id @default(uuid())
  tradeId     String    @map("trade_id")
  percentage  Float     // Position percentage (0-100)
  rr          Float     // Risk-reward ratio for this partial (> 0)
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  trade       Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@map("trade_partials")
  @@index([tradeId])
}

// ============================================================================
// JOURNAL ATTRIBUTE MODEL
// ============================================================================
// Defines custom attributes that can be attached to trades in a specific journal
// Each journal can have its own set of custom attributes
// Examples: "Strategy", "Market Condition", "Screenshot", "Notes"

model JournalAttribute {
  id          String    @id @default(uuid())
  journalId   String    @map("journal_id")
  name        String    // Attribute name (e.g., "Strategy", "Market Condition")
  type        AttributeType @default(TEXT) // Data type for the attribute
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  journal     Journal   @relation(fields: [journalId], references: [id], onDelete: Cascade)
  values      TradeAttributeValue[]

  @@map("journal_attributes")
  @@index([journalId])
  @@unique([journalId, name]) // Prevent duplicate attribute names per journal
}

// ============================================================================
// TRADE ATTRIBUTE VALUE MODEL
// ============================================================================
// Stores the actual values for custom attributes on individual trades
// Uses separate columns for each data type to avoid JSON and enable proper indexing
// Only one value column should be populated per row (based on JournalAttribute.type)

model TradeAttributeValue {
  id                String    @id @default(uuid())
  tradeId           String    @map("trade_id")
  journalAttributeId String   @map("journal_attribute_id")
  valueText         String?   @map("value_text")     // For TEXT type attributes
  valueNumber       Float?    @map("value_number")   // For NUMBER type attributes
  valueBoolean      Boolean?  @map("value_boolean")  // For BOOLEAN type attributes
  valueImageUrl     String?   @map("value_image_url") // For IMAGE type attributes (URL to stored image)
  createdAt         DateTime  @default(now()) @map("created_at")

  // Relations
  trade             Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  journalAttribute JournalAttribute @relation(fields: [journalAttributeId], references: [id], onDelete: Cascade)

  @@map("trade_attribute_values")
  @@index([tradeId])
  @@index([journalAttributeId])
  @@unique([tradeId, journalAttributeId]) // One value per attribute per trade
}

// ============================================================================
// ENUMS
// ============================================================================

enum AttributeType {
  TEXT    // String values (e.g., "Strategy name", "Notes")
  NUMBER  // Numeric values (e.g., "Position size", "Entry price")
  BOOLEAN // True/false values (e.g., "Followed plan", "Revenge trade")
  IMAGE   // Image URLs (e.g., "Screenshot", "Chart")
}

// ============================================================================
// ANALYTICS NOTES
// ============================================================================
// The schema is optimized for the following analytics queries:
//
// 1. EQUITY CURVE:
//    - Query: trades ordered by tradeDate, sum profitLoss cumulatively
//    - Index: [journalId, tradeDate, profitLoss] supports this efficiently
//
// 2. WIN RATE:
//    - Query: COUNT(*) WHERE isWin = true / COUNT(*)
//    - Index: [journalId, isWin] enables fast filtering
//
// 3. RISK/REWARD ANALYSIS:
//    - Query: AVG(riskReward) WHERE isWin = true/false
//    - Index: [journalId, isWin] supports grouping
//
// 4. CALENDAR P&L:
//    - Query: SUM(profitLoss) GROUP BY DATE(tradeDate)
//    - Index: [journalId, tradeDate] enables date-based grouping
//
// 5. CUSTOM ATTRIBUTE ANALYTICS:
//    - Query trades filtered by TradeAttributeValue values
//    - Indexes on tradeId and journalAttributeId support joins
//
// 6. CAPITAL TRACKING:
//    - currentCapital in Journal is updated after each trade
//    - Can be recalculated from trades if needed: startingCapital + SUM(profitLoss)

